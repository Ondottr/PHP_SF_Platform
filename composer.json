{
  "name": "nations-original/php-simple-framework",
  "description": "A simple PHP framework for Nations Original.",
  "authors": [
    {
      "name": "Dmytro Dyvulskyi",
      "role": "CEO & Founder and Lead Developer of Nations Original",
      "email": "eklerk397@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "PHP_SF\\System\\": "src/",
      "PHP_SF\\Framework\\": "app/",
      "PHP_SF\\Templates\\": "templates/",
      "PHP_SF\\Tests\\": "tests/"
    },
    "files": [
      "functions/functions.php",
      "functions/time_functions.php",
      "functions/view_functions.php"
    ]
  },
  "license": "ISC",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": "8.3.*",
    "nations-original/php-sf-cache": "^2.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "phpstan/phpstan": "^2.0",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan-doctrine": "^2.0",
    "phpstan/phpstan-symfony": "^2.0",
    "phpstan/phpstan-phpunit": "^2.0"
  },
  "scripts": {
    "stan": "phpstan analyse --no-progress"
  },
  "extra": {
    "phpstan": {
      "includes": [
        "phpstan-extension.neon"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
